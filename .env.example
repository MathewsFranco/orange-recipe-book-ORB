# Supabase (public — safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Supabase (server-only — never NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Spoonacular (server-only — never NEXT_PUBLIC_)
SPOONACULAR_API_KEY=your-spoonacular-api-key

# Admin endpoint secret (server-only — never NEXT_PUBLIC_)
ADMIN_SECRET=your-random-secret-here
